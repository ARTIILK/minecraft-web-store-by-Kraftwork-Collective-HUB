{
    "version": 2,
    "functions": {
        "dist/index.js": {
            "maxDuration": 10
        }
    },
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "dist/index.js"
        },
        {
            "src": "/assets/(.*)",
            "dest": "dist/public/assets/$1"
        },
        {
            "src": "/(.*)",
            "dest": "dist/index.js"
        }
    ]
}